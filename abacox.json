{
  "name": "telephony-pricing",
  "displayName": "Telephony Pricing",
  "usesDatabase": true,
  "usesObjectStorage": true,
  "containerPort": 8080,
  "memoryLimit": "2048M",
  "coreModule": false,
  "dockerfilePath": "Dockerfile",
  "contextPath": ".",
  "dependsOn": ["control", "core", "users"],
  "requiresControlRegistration": true,
  "skipHealthCheck": false,
  "healthCheckPath": "/actuator/health/liveness",
  "jpaHibernateDdlAuto": "none",
  "forwardHeadersNative": false,
  "volumes": ["${ABACOX_MODULE_DIR}:/app/data"]
}
